<head>
  <style>
    body {
  font-family: 'Inter', sans-serif;
  background: linear-gradient(#1a1a22, #2a1f2f);
  color: #e5e5e5;
  margin: 0;
  padding: 20px 20px 60px 20px;
  text-align: center;
  min-height: 100vh;
  box-sizing: border-box;
}

/* title */
h1 {
  font-family: 'UnifrakturMaguntia', cursive;
  font-size: 36px;
  color: #d6b3ff;
  margin-bottom: 20px;
}

/* container */
.container {
  max-width: 500px;
  margin: auto;
  background: rgba(0,0,0,0.3);
  padding: 20px;
  border-radius: 20px;
  border: 1px solid #3a2a40;
}

/* cards */
.card {
  background: linear-gradient(#2a2230, #1c1c24);
  padding: 12px;
  margin-bottom: 10px;
  border-radius: 12px;
  border: 1px solid #4a3a55;
  text-align: left;

  display: flex;
  flex-direction: column;
  gap: 6px;
}

/* headings */
h3 {
  font-size: 13px;
  color: #c084fc;
  margin: 0 0 6px 0;
}

/* paragraph inside cards */
.card p {
  font-size: 12px;
  color: #d1d1d1;
  line-height: 1.5;
  margin: 0;
  opacity: 0.7;
}

/* dropdowns */
select {
  width: 100%;
  padding: 8px;
  border-radius: 8px;
  background: #120f18;
  color: #fff;
  border: 1px solid #4a3a55;
}

/* button */
button {
  width: 100%;
  padding: 12px;
  border-radius: 12px;
  border: none;
  background: linear-gradient(to right, #a855f7, #ec4899);
  color: white;
  font-size: 15px;
  margin-top: 12px;
  cursor: pointer;
}

/* result */
#result {
  margin-top: 15px;
  font-size: 20px;
  color: #f9a8d4;
}

/* history items */
#history div {
  font-size: 12px;
  padding: 6px 0;
  border-bottom: 1px solid #3a2a40;
  opacity: 0.85;
}

/* 📱 Mobile */
@media (max-width: 600px) {
  body {
    padding: 10px;
  }

  h1 {
    font-size: 28px;
  }

  .container {
    max-width: 100%;
  }
}

/* 💻 Desktop */
@media (min-width: 900px) {
  .container {
    max-width: 600px;
  }
}
.card label {
  font-size: 14px;
  color: #e5e5e5;
  display: flex;
  align-items: center;
  gap: 8px;
  margin: 6px 0;
}
.card input[type="checkbox"] {
  width: 14px;
  height: 14px;
  accent-color: #a855f7;
}


  </style>
</head>

