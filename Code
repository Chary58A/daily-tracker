function getRandomQuote() {
  return quotes[Math.floor(Math.random() * quotes.length)];
}

function renderQuote() {
  let quoteEl = document.getElementById("quote");
  if (!quoteEl) return;

  quoteEl.innerText = getRandomQuote();
}
window.onload = function () {
