<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link href="https://fonts.googleapis.com/css2?family=UnifrakturMaguntia&family=Inter&display=swap" rel="stylesheet">

  <style>
    body {
  font-family: 'Inter', sans-serif;
  background: linear-gradient(#1a1a22, #2a1f2f);
  color: #e5e5e5;
  margin: 0;
  padding: 20px;
  text-align: center;
}

/* title */
h1 {
  font-family: 'UnifrakturMaguntia', cursive;
  font-size: 36px;
  color: #d6b3ff;
  margin-bottom: 20px;
}

/* container */
.container {
  max-width: 500px;
  margin: auto;
  background: rgba(0,0,0,0.3);
  padding: 15px;
  border-radius: 20px;
  border: 1px solid #3a2a40;
}

/* cards */
.card {
  background: linear-gradient(#2a2230, #1c1c24);
  padding: 12px;
  margin-bottom: 10px;
  border-radius: 12px;
  border: 1px solid #4a3a55;
  text-align: left;
}

/* headings */
h3 {
  font-size: 13px;
  color: #c084fc;
  margin-bottom: 6px;
}

/* dropdowns */
select {
  width: 100%;
  padding: 8px;
  border-radius: 8px;
  background: #120f18;
  color: #fff;
  border: 1px solid #4a3a55;
}

/* button */
button {
  width: 100%;
  padding: 12px;
  border-radius: 12px;
  border: none;
  background: linear-gradient(to right, #a855f7, #ec4899);
  color: white;
  font-size: 15px;
  margin-top: 12px;
}

/* result */
#result {
  margin-top: 15px;
  font-size: 20px;
  color: #f9a8d4;
}
/* 📱 Mobile improvements */
@media (max-width: 600px) {
  body {
    padding: 10px;
  }

  h1 {
    font-size: 28px;
  }

  .container {
    max-width: 100%;
  }
}

/* 💻 Desktop improvements */
@media (min-width: 900px) {
  .container {
    max-width: 600px;
  }
}
  </style>
</head>

<body>

  <link href="https://fonts.googleapis.com/css2?family=UnifrakturMaguntia&family=Inter&display=swap" rel="stylesheet">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<h1>✧ My Daily Ritual ✧</h1>
<div class="container">

	<div class="card">
		<h3>Calorie Intake</h3>
  		<select id="intake">
   			<option value="10">0-200 (10 pts)</option>
  			<option value="8">201-350 (8 pts)</option>
  			<option value="5">351-500 (5 pts)</option>
 			<option value="3">501-600 (3 pts)</option>
 			<option value="1">601-750  (1 pt)</option>
			<option value="0">over 750 (0 pts)</option>
		</select>
	</div>

	<div class="card">
		<h3>Exercise</h3>
		<select id="exercise">
			<option value="0">none (0)</option>
			<option value="2">15 minutes (2)</option>
			<option value="5">30 minutes (5)</option>
			<option value="8">45 minutes (8)</option>
			<option value="10">1+ hours (10)</option>
			<option value="2">1 hour bicycle / 45 min walk (bonus +2)</option>
		</select>
	</div>

	<div class="card">
		<h3>Water Intake</h3>
		<select id="water">
			<option value="0">0 glasses</option>
			<option value="1">1 glass</option>
			<option value="2">2 glasses</option>
			<option value="3">3 glasses</option>
			<option value="4">4 glasses</option>
			<option value="6">5 glasses</option>
			<option value="7">6 glasses</option>
			<option value="8">7 glasses</option>
			<option value="9">8 glasses</option>
			<option value="10">9 glasses</option>
		</select>
	</div>

	<div class="card">
		<h3>Sleeping Hours</h3>
		<select id="sleep">
			<option value="10">8+ hours</option>
			<option value="8">7 hours</option>
			<option value="7">6 hours</option>
			<option value="5">5 hours</option>
			<option value="4">4 hours</option>
			<option value="2">3 hours</option>
			<option value="0">2 hours or less</option>
		</select>
	</div>

 	<div class="card">
		<h3>Bonus</h3>
		<label><input type="checkbox" value="3" class="bonus"> Journal</label><br>
		<label><input type="checkbox" value="2" class="bonus"> No binging</label><br>
		<label><input type="checkbox" value="2" class="bonus"> Posting thinspiration</label><br>
		<label><input type="checkbox" value="2" class="bonus"> Recording calories</label><br>
		<label><input type="checkbox" value="2" class="bonus"> Placeholder</label>
	</div>

</div>

<button onclick="calculate()">Calculate</button>

<h2 id="result">Score: 0</h2>

  <script>
    function calculate() {
  let intake = Number(document.getElementById("intake").value);
  let exercise = Number(document.getElementById("exercise").value);
  let water = Number(document.getElementById("water").value);
  let sleep = Number(document.getElementById("sleep").value);

  let bonus = 0;
  document.querySelectorAll(".bonus").forEach(cb => {
    if (cb.checked) {
      bonus += Number(cb.value);
    }
  });

  let total = intake + exercise + water + sleep + bonus;

  document.getElementById("result").innerText = "Score: " + total;
}
  </script>

</body>
</html>
